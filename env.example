# Shopify PO Seeder - Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Storage
SESSIONS_DIR=./sessions
SESSION_ENCRYPTION_KEY=your-secure-encryption-key-change-this-in-production

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_SLOW_MO=0

# Shopify Configuration (Optional - for API integrations)
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SHOPIFY_API_VERSION=2024-01

# PO Generation Settings
MAX_RETRIES=3
RETRY_DELAY=2000
BATCH_SIZE=50
PROGRESS_UPDATE_INTERVAL=5

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/po-seeder.log

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_PO_GENERATION=true
ENABLE_SESSION_ENCRYPTION=true
ENABLE_PROGRESS_TRACKING=true
CLEANUP_OLD_SESSIONS=true
CLEANUP_DAYS_OLD=30
